# insurance_hermes — environment template
# Copy this file to `.env` and fill in real values.
# `.env` is gitignored and MUST NOT be committed.

# --- Hostinger VPS / SSH connection ---
# Hostname or IP of the VPS
VPS_HOST=

# SSH user (typically `root` on a fresh Hostinger VPS, or a non-root sudo user)
VPS_USER=

# SSH port (Hostinger default is 22)
VPS_PORT=22

# Absolute path to the private key used to connect (kept OUTSIDE the repo)
# e.g. ~/.ssh/hostinger_insurance_hermes
VPS_SSH_KEY_PATH=

# --- Docker manager ---
# URL of the Docker management UI on the VPS (e.g. Portainer / Dokploy)
DOCKER_MANAGER_URL=

# --- Telegram bot (BotFather) ---
# HTTP API token issued by @BotFather (format: 123456789:AA...). Secret.
TELEGRAM_BOT_TOKEN=

# Your Telegram numeric user ID — used to restrict who the bot will talk to.
# Get it by messaging @userinfobot.
TELEGRAM_ADMIN_CHAT_ID=
