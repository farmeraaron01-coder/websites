# RingCentral credentials for download_recordings.py
# Copy this file to ".env" and fill in your real values.
# Your real .env lives at:
#   C:\Users\AaronFarmer\Farmer Agency Dropbox\Aaron Farmer\Claude CoWork Files\RingCentral\.env
# (the script reads that path by default; override with the RC_ENV_FILE env var)

# --- Required: from your RingCentral app (developers.ringcentral.com) ---
RC_CLIENT_ID=your_app_client_id
RC_CLIENT_SECRET=your_app_client_secret

# The long JWT string you generated as a "JWT credential" in the RC console.
RC_JWT=your_jwt_credential_string

# --- Optional ---
# Production: https://platform.ringcentral.com  (default)
# Sandbox:    https://platform.devtest.ringcentral.com
RC_SERVER_URL=https://platform.ringcentral.com

# Where to save recordings. Point this at your Google Drive folder, e.g.:
#   RC_OUTPUT_DIR=G:\My Drive\RingCentral Recordings
# (use the real drive letter / path of your Google Drive on this PC)
RC_OUTPUT_DIR=G:\My Drive\RingCentral Recordings

# How many days back to pull (RingCentral retains ~90 days). Default 60.
RC_LOOKBACK_DAYS=60
